# Frontend environment template — copy to `.env.local` for personal overrides.
# `.env*` files (other than this example) are gitignored.
#
# Phase 0 surface only. Phase 1 onwards may add more.

# Absolute URL of the backend API. Leave unset in dev to use the Vite proxy.
# Set to the Render service URL (e.g. https://agentic-claims-poc.onrender.com)
# in deployed environments.
VITE_API_BASE_URL=
