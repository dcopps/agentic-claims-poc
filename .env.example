# Environment variables — copy to `.env` and fill in.
#
# `.env` is gitignored; never commit a populated copy. Render's
# Environment tab is the deployed-backend equivalent — set the same vars
# there so the deployed service has the same configuration.
#
# Each variable below is documented with the phase that consumes it. A
# Phase 2 placeholder is left empty in Phase 1 so the file shape is
# stable across the build; the value can be added when the consumer
# lands without re-editing the rest of the file.

# Phase 1 — required.
# Postgres connection string. The deployed prototype uses Neon (managed
# Postgres) in eu-central-1 (Frankfurt) with pgvector 0.8.0 enabled.
# Local development can either run native Postgres (see scripts/setup-dev-db.sh)
# or point this at a Neon dev branch URL.
DATABASE_URL=postgresql://localhost/agentic_claims_dev

# Phase 2 — Anthropic API key. Optional in Phase 1; required when the
# LLM Gateway lands.
ANTHROPIC_API_KEY=

# Phase 2 — Mistral API key. Optional in Phase 1; required when the LLM
# Gateway lands.
MISTRAL_API_KEY=
